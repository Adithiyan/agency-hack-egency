# Phantom Flow environment variables.
# Copy to `.env` and fill in real values. Never commit `.env`.

ANTHROPIC_API_KEY=

# Optional. Override grants dataset URL for ingestion.
PHANTOM_FLOW_GRANTS_URL=

# Optional. Path to cached grants CSV. If set, ingest skips download.
PHANTOM_FLOW_GRANTS_CSV=data/raw/grants.csv

# Optional. Toggle live Corporations Canada lookups vs cached fixture.
PHANTOM_FLOW_USE_LIVE_CORP=false
